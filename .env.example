# Copie este arquivo para .env e ajuste os valores antes de hospedar.

# Chave secreta (use um valor longo e aleatório em produção)
SECRET_KEY=troque-esta-chave-por-algo-bem-aleatorio

# Credenciais do administrador (criadas na primeira execução do init_db.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Banco de dados (padrão: SQLite local). Para Postgres, por exemplo:
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Itens por página nas listagens
ITEMS_PER_PAGE=10
